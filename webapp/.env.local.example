# Copy this file to `.env.local` and fill in your own values.

# Strava OAuth credentials. Obtain these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Your authorised redirect URI for local development should match the
# callback defined in pages/api/strava/callback.js. When developing
# locally this is usually http://localhost:3000/api/strava/callback.
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# Supabase project URL and anon key (found in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional service-role secret if you choose to use it for server-side work.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used in OAuth redirects and emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret used to protect scheduled Strava sync requests.
CRON_SECRET=

# Google OAuth uses Supabase Auth. Configure the Google provider inside Supabase,
# then make sure this redirect URL is added there:
# http://localhost:3000/auth/callback

# Resend welcome emails. If blank, signups still work and emails are skipped.
RESEND_API_KEY=

# Stripe billing/webhook support.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_RESEARCH_MONTHLY=
STRIPE_PRICE_INDIVIDUAL_MONTHLY=
STRIPE_PRICE_INDIVIDUAL_ANNUAL=
STRIPE_PRICE_COACH_MONTHLY=
STRIPE_PRICE_COACH_ANNUAL=

# Server-side Postgres connection for admin-only content workflows.
SUPABASE_DB_URL=

# Recommended contact email for PubMed E-utilities.
NCBI_CONTACT_EMAIL=
