# Copy this file to `.env.local` and fill in your own values.

# Strava OAuth credentials. Obtain these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Your authorised redirect URI for local development should match the
# callback defined in pages/api/strava/callback.js. When developing
# locally this is usually http://localhost:3000/api/strava/callback.
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# Supabase project URL and anon key (found in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key is optional but can be used in server‑side code if
# you enable Row Level Security. Keep it secret and never expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=
